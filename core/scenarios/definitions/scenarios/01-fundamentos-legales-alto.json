    "objectives": [
      "Reconocer que una orden vial exige conducta concreta, no solo conocimiento teórico.",
      "Detener el vehículo antes de la línea y ceder el paso cuando corresponde."
    ],
    "feedback": {
      "success": "Te detuviste por completo, observaste el cruce y avanzaste con margen.",
